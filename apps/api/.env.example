# Which env file to load. Omit to use .env; set for local/test:
#   ENV_FILE=.env.local  – local app (uvicorn)
#   ENV_FILE=.env.test   – tests (pytest)
# ENV_FILE=.env

# PostgreSQL (async driver for app; use postgresql:// for Alembic sync)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/expense_manager

# Optional: separate DB for tests (pytest uses this when set)
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/expense_manager_test
